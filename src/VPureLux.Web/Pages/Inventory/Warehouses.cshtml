@page
@model VPureLux.Web.Pages.Inventory.WarehousesModel
@inject Microsoft.Extensions.Localization.IStringLocalizer<VPureLux.Localization.VPureLuxResource> L
@{ ViewData["Title"] = L["Inventory:Warehouses"]; }

@section scripts {
    <abp-script src="/Pages/Inventory/Warehouses.js" />
}

<div data-warehouses-page
     data-status-success="@(string.IsNullOrWhiteSpace(Model.StatusMessageKey) ? string.Empty : L[Model.StatusMessageKey].Value)"></div>

<h2>@L["Inventory:Warehouses"]</h2>

<div asp-validation-summary="All" class="text-danger mb-3"></div>

<form method="post" class="row g-2 mb-4">
    <div class="col">
        <input asp-for="NewWarehouse.Code" class="form-control" placeholder="@L["Inventory:Code"]" />
        <span asp-validation-for="NewWarehouse.Code" class="text-danger"></span>
    </div>
    <div class="col">
        <input asp-for="NewWarehouse.Name" class="form-control" placeholder="@L["Inventory:Name"]" />
        <span asp-validation-for="NewWarehouse.Name" class="text-danger"></span>
    </div>
    <div class="col">
        <input asp-for="NewWarehouse.Address" class="form-control" placeholder="@L["Inventory:Address"]" />
        <span asp-validation-for="NewWarehouse.Address" class="text-danger"></span>
    </div>
    <div class="col-auto d-flex align-items-start">
        <button type="submit" class="btn btn-primary">@L["Create"]</button>
    </div>
</form>

<abp-table striped-rows="true">
    <thead>
        <tr>
            <th>@L["Inventory:Code"]</th>
            <th>@L["Inventory:Name"]</th>
            <th>@L["Inventory:Status"]</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @foreach (var x in Model.Warehouses)
    {
        <tr>
            <td>@x.Code</td>
            <td>@x.Name</td>
            <td>@L[$"Status:{x.Status}"]</td>
            <td>
                <form method="post"
                      asp-page-handler="@(x.Status == VPureLux.Inventory.InventoryEntityStatus.Active ? "Deactivate" : "Activate")"
                      asp-route-id="@x.Id"
                      data-warehouse-status-form
                      data-confirm-message="@(x.Status == VPureLux.Inventory.InventoryEntityStatus.Active ? L["Inventory:ConfirmDeactivateWarehouse"].Value : L["Inventory:ConfirmActivateWarehouse"].Value)">
                    <button type="submit" class="btn btn-sm btn-outline-secondary">
                        @(x.Status == VPureLux.Inventory.InventoryEntityStatus.Active ? L["Deactivate"] : L["Activate"])
                    </button>
                </form>
            </td>
        </tr>
    }
    </tbody>
</abp-table>
