@page
@model VPureLux.Web.Pages.Inventory.AdjustmentModel
@inject Microsoft.Extensions.Localization.IStringLocalizer<VPureLux.Localization.VPureLuxResource> L
@{
    ViewData["Title"] = L["Inventory:Adjustment"];
    var postSuccessMessageKey = TempData["InventoryPostSuccessMessage"] as string;
}

<div data-inventory-posting-page
     data-post-success="@(postSuccessMessageKey == null ? null : L[postSuccessMessageKey].Value)"
     data-adjustment-increase-value="@((byte)VPureLux.Inventory.InventoryTransactionType.AdjustmentIncrease)">
    <h2>@L["Inventory:Adjustment"]</h2>
</div>

<abp-card>
    <abp-card-body>
        <form method="post" data-inventory-posting-form data-confirm-message="@L["Inventory:ConfirmPostAdjustment"]">
            <input asp-for="IdempotencyKey" type="hidden" />
            <div asp-validation-summary="All" class="text-danger"></div>

            <div class="mb-3">
                <label asp-for="WarehouseId" class="form-label">@L["Inventory:Warehouse"]</label>
                <select asp-for="WarehouseId" asp-items="Model.WarehouseOptions" class="form-select">
                    <option value="">@L["Select"]</option>
                </select>
                <span asp-validation-for="WarehouseId" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Type" class="form-label">@L["Inventory:Type"]</label>
                <select asp-for="Type" class="form-select" data-adjustment-type>
                    <option value="@((byte)VPureLux.Inventory.InventoryTransactionType.AdjustmentDecrease)">@L["Inventory:TransactionType:AdjustmentDecrease"]</option>
                    <option value="@((byte)VPureLux.Inventory.InventoryTransactionType.AdjustmentIncrease)">@L["Inventory:TransactionType:AdjustmentIncrease"]</option>
                </select>
                <span asp-validation-for="Type" class="text-danger"></span>
            </div>
            <abp-input asp-for="Reason" />

            <div data-adjustment-decrease-section>
                <h5 class="mt-4">@L["Inventory:DecreaseLines"]</h5>
                <div id="adjustment-decrease-lines" data-inventory-line-container data-add-button="#add-adjustment-decrease-line">
                    @for (var i = 0; i < Model.DecreaseLines.Count; i++)
                    {
                        <div class="border rounded p-3 mb-3" data-inventory-line-row>
                            <div class="row g-3 align-items-end">
                                <div class="col-md-8">
                                    <label class="form-label" for="DecreaseLines_@i.ToString()__StockItemId"
                                           data-for="DecreaseLines___index____StockItemId">@L["Inventory:StockItem"]</label>
                                    <select class="form-select"
                                            name="DecreaseLines[@i].StockItemId"
                                            id="DecreaseLines_@i.ToString()__StockItemId"
                                            data-name="DecreaseLines[__index__].StockItemId"
                                            data-id="DecreaseLines___index____StockItemId">
                                        <option value="">@L["Select"]</option>
                                        @foreach (var option in Model.StockItemOptions)
                                        {
                                            if (InventoryPostingUi.IsOptionSelected(option.Value!, Model.DecreaseLines[i].StockItemId))
                                            {
                                                <option value="@option.Value" selected="selected">@option.Text</option>
                                            }
                                            else
                                            {
                                                <option value="@option.Value">@option.Text</option>
                                            }
                                        }
                                    </select>
                                    <span class="text-danger" data-valmsg-for="DecreaseLines[@i].StockItemId"
                                          data-valmsg-for-template="DecreaseLines[__index__].StockItemId" data-valmsg-replace="true"></span>
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label" for="DecreaseLines_@i.ToString()__Quantity"
                                           data-for="DecreaseLines___index____Quantity">@L["Inventory:Quantity"]</label>
                                    <input class="form-control" name="DecreaseLines[@i].Quantity" id="DecreaseLines_@i.ToString()__Quantity"
                                           value="@Model.DecreaseLines[i].Quantity" data-name="DecreaseLines[__index__].Quantity"
                                           data-id="DecreaseLines___index____Quantity" />
                                    <span class="text-danger" data-valmsg-for="DecreaseLines[@i].Quantity"
                                          data-valmsg-for-template="DecreaseLines[__index__].Quantity" data-valmsg-replace="true"></span>
                                </div>
                                <div class="col-md-1 text-end">
                                    <button class="btn btn-outline-danger btn-sm" type="button" data-remove-line>@L["Inventory:RemoveLine"]</button>
                                </div>
                            </div>
                        </div>
                    }
                </div>
                <button class="btn btn-outline-secondary" type="button" id="add-adjustment-decrease-line">@L["Inventory:AddLine"]</button>
            </div>

            <div data-adjustment-increase-section>
                <h5 class="mt-4">@L["Inventory:IncreaseLines"]</h5>
                <div id="adjustment-increase-lines" data-inventory-line-container data-add-button="#add-adjustment-increase-line">
                    @for (var i = 0; i < Model.IncreaseLines.Count; i++)
                    {
                        <div class="border rounded p-3 mb-3" data-inventory-line-row>
                            <div class="row g-3 align-items-end">
                                <div class="col-md-4">
                                    <label class="form-label" for="IncreaseLines_@i.ToString()__StockItemId"
                                           data-for="IncreaseLines___index____StockItemId">@L["Inventory:StockItem"]</label>
                                    <select class="form-select"
                                            name="IncreaseLines[@i].StockItemId"
                                            id="IncreaseLines_@i.ToString()__StockItemId"
                                            data-name="IncreaseLines[__index__].StockItemId"
                                            data-id="IncreaseLines___index____StockItemId">
                                        <option value="">@L["Select"]</option>
                                        @foreach (var option in Model.StockItemOptions)
                                        {
                                            if (InventoryPostingUi.IsOptionSelected(option.Value!, Model.IncreaseLines[i].StockItemId))
                                            {
                                                <option value="@option.Value" selected="selected">@option.Text</option>
                                            }
                                            else
                                            {
                                                <option value="@option.Value">@option.Text</option>
                                            }
                                        }
                                    </select>
                                    <span class="text-danger" data-valmsg-for="IncreaseLines[@i].StockItemId"
                                          data-valmsg-for-template="IncreaseLines[__index__].StockItemId" data-valmsg-replace="true"></span>
                                </div>
                                <div class="col-md-2">
                                    <label class="form-label" for="IncreaseLines_@i.ToString()__Quantity"
                                           data-for="IncreaseLines___index____Quantity">@L["Inventory:Quantity"]</label>
                                    <input class="form-control" name="IncreaseLines[@i].Quantity" id="IncreaseLines_@i.ToString()__Quantity"
                                           value="@Model.IncreaseLines[i].Quantity" data-name="IncreaseLines[__index__].Quantity"
                                           data-id="IncreaseLines___index____Quantity" />
                                    <span class="text-danger" data-valmsg-for="IncreaseLines[@i].Quantity"
                                          data-valmsg-for-template="IncreaseLines[__index__].Quantity" data-valmsg-replace="true"></span>
                                </div>
                                <div class="col-md-2">
                                    <label class="form-label" for="IncreaseLines_@i.ToString()__LotNo"
                                           data-for="IncreaseLines___index____LotNo">@L["Inventory:LotNo"]</label>
                                    <input class="form-control" name="IncreaseLines[@i].LotNo" id="IncreaseLines_@i.ToString()__LotNo"
                                           value="@Model.IncreaseLines[i].LotNo" data-name="IncreaseLines[__index__].LotNo"
                                           data-id="IncreaseLines___index____LotNo" />
                                    <span class="text-danger" data-valmsg-for="IncreaseLines[@i].LotNo"
                                          data-valmsg-for-template="IncreaseLines[__index__].LotNo" data-valmsg-replace="true"></span>
                                </div>
                                <div class="col-md-2">
                                    <label class="form-label" for="IncreaseReceivedAtTexts_@i.ToString()_"
                                           data-for="IncreaseReceivedAtTexts___index___">@L["Inventory:ReceivedAt"]</label>
                                    <input class="form-control" name="IncreaseReceivedAtTexts[@i]" id="IncreaseReceivedAtTexts_@i.ToString()_"
                                           value="@Model.IncreaseReceivedAtTexts[i]" inputmode="numeric" placeholder="dd/MM/yyyy"
                                           data-default-value="@Model.DefaultDateText"
                                           data-name="IncreaseReceivedAtTexts[__index__]" data-id="IncreaseReceivedAtTexts___index___" />
                                    <span class="text-danger" data-valmsg-for="IncreaseReceivedAtTexts[@i]"
                                          data-valmsg-for-template="IncreaseReceivedAtTexts[__index__]" data-valmsg-replace="true"></span>
                                </div>
                                <div class="col-md-2">
                                    <label class="form-label" for="IncreaseLines_@i.ToString()__UnitCost"
                                           data-for="IncreaseLines___index____UnitCost">@L["Inventory:UnitCost"]</label>
                                    <input class="form-control" name="IncreaseLines[@i].UnitCost" id="IncreaseLines_@i.ToString()__UnitCost"
                                           value="@Model.IncreaseLines[i].UnitCost" data-name="IncreaseLines[__index__].UnitCost"
                                           data-id="IncreaseLines___index____UnitCost" />
                                    <span class="text-danger" data-valmsg-for="IncreaseLines[@i].UnitCost"
                                          data-valmsg-for-template="IncreaseLines[__index__].UnitCost" data-valmsg-replace="true"></span>
                                </div>
                                <div class="col-md-12 text-end">
                                    <button class="btn btn-outline-danger btn-sm" type="button" data-remove-line>@L["Inventory:RemoveLine"]</button>
                                </div>
                            </div>
                        </div>
                    }
                </div>
                <button class="btn btn-outline-secondary" type="button" id="add-adjustment-increase-line">@L["Inventory:AddLine"]</button>
            </div>

            <button class="btn btn-primary" type="submit">@L["Inventory:Post"]</button>
        </form>
    </abp-card-body>
</abp-card>

@section scripts {
    <abp-script src="/Pages/Shared/DynamicRowSelects.js" />
    <abp-script src="/Pages/Inventory/Posting.js" />
}
