@page
@model VPureLux.Web.Pages.Inventory.ReceiptModel
@inject Microsoft.Extensions.Localization.IStringLocalizer<VPureLux.Localization.VPureLuxResource> L
@{
    ViewData["Title"] = L["Inventory:Receipt"];
    var postSuccessMessageKey = TempData["InventoryPostSuccessMessage"] as string;
}

<div data-inventory-posting-page data-post-success="@(postSuccessMessageKey == null ? null : L[postSuccessMessageKey].Value)">
    <h2>@L["Inventory:Receipt"]</h2>
</div>

<abp-card class="vpl-entry-surface">
    <abp-card-body>
        <form method="post" data-inventory-posting-form data-confirm-message="@L["Inventory:ConfirmPostReceipt"]">
            <input asp-for="Input.IdempotencyKey" type="hidden" />
            <div asp-validation-summary="All" class="text-danger"></div>

            <div class="mb-3">
                <label asp-for="Input.WarehouseId" class="form-label">@L["Inventory:Warehouse"]</label>
                <select asp-for="Input.WarehouseId" asp-items="Model.WarehouseOptions" class="form-select">
                    <option value="">@L["Select"]</option>
                </select>
                <span asp-validation-for="Input.WarehouseId" class="text-danger"></span>
            </div>

            <h5 class="mt-4">@L["Inventory:Lines"]</h5>
            <div class="vpl-line-editor table-responsive">
                <table class="table table-sm table-bordered align-middle mb-0 vpl-line-editor-table inventory-receipt-lines-table">
                    <thead class="table-light">
                        <tr>
                            <th class="vpl-line-editor-col-main">@L["Inventory:StockItem"]</th>
                            <th class="vpl-line-editor-col-number">@L["Inventory:Quantity"]</th>
                            <th class="vpl-line-editor-col-text">@L["Inventory:LotNo"]</th>
                            <th class="vpl-line-editor-col-date">@L["Inventory:ReceivedAt"]</th>
                            <th class="vpl-line-editor-col-number">@L["Inventory:UnitCost"]</th>
                            <th class="vpl-line-editor-col-action text-end">@L["Actions"]</th>
                        </tr>
                    </thead>
                    <tbody id="receipt-lines" data-inventory-line-container data-add-button="#add-receipt-line" data-row-template="receipt-line-row-template">
                    @for (var i = 0; i < Model.Input.Lines.Count; i++)
                    {
                        <tr data-inventory-line-row data-line-editor-row>
                            <td class="vpl-line-editor-col-main">
                                <label class="visually-hidden" for="Input_Lines_@i.ToString()__StockItemId"
                                       data-for="Input_Lines___index____StockItemId">@L["Inventory:StockItem"]</label>
                                <select class="form-select form-select-sm"
                                        name="Input.Lines[@i].StockItemId"
                                        id="Input_Lines_@i.ToString()__StockItemId"
                                        data-dynamic-select2="disabled"
                                        data-name="Input.Lines[__index__].StockItemId"
                                        data-id="Input_Lines___index____StockItemId">
                                    <option value="">@L["Select"]</option>
                                    @foreach (var option in Model.StockItemOptions)
                                    {
                                        if (InventoryPostingUi.IsOptionSelected(option.Value!, Model.Input.Lines[i].StockItemId))
                                        {
                                            <option value="@option.Value" selected="selected">@option.Text</option>
                                        }
                                        else
                                        {
                                            <option value="@option.Value">@option.Text</option>
                                        }
                                    }
                                </select>
                                <span class="text-danger small" data-valmsg-for="Input.Lines[@i].StockItemId"
                                      data-valmsg-for-template="Input.Lines[__index__].StockItemId" data-valmsg-replace="true"></span>
                            </td>
                            <td class="vpl-line-editor-col-number">
                                <label class="visually-hidden" for="Input_Lines_@i.ToString()__Quantity"
                                       data-for="Input_Lines___index____Quantity">@L["Inventory:Quantity"]</label>
                                <input class="form-control form-control-sm" name="Input.Lines[@i].Quantity" id="Input_Lines_@i.ToString()__Quantity"
                                       value="@Model.Input.Lines[i].Quantity" data-name="Input.Lines[__index__].Quantity"
                                       data-id="Input_Lines___index____Quantity" />
                                <span class="text-danger small" data-valmsg-for="Input.Lines[@i].Quantity"
                                      data-valmsg-for-template="Input.Lines[__index__].Quantity" data-valmsg-replace="true"></span>
                            </td>
                            <td class="vpl-line-editor-col-text">
                                <label class="visually-hidden" for="Input_Lines_@i.ToString()__LotNo"
                                       data-for="Input_Lines___index____LotNo">@L["Inventory:LotNo"]</label>
                                <input class="form-control form-control-sm" name="Input.Lines[@i].LotNo" id="Input_Lines_@i.ToString()__LotNo"
                                       value="@Model.Input.Lines[i].LotNo" data-name="Input.Lines[__index__].LotNo"
                                       data-id="Input_Lines___index____LotNo" />
                                <span class="text-danger small" data-valmsg-for="Input.Lines[@i].LotNo"
                                      data-valmsg-for-template="Input.Lines[__index__].LotNo" data-valmsg-replace="true"></span>
                            </td>
                            <td class="vpl-line-editor-col-date">
                                <label class="visually-hidden" for="ReceivedAtTexts_@i.ToString()_"
                                       data-for="ReceivedAtTexts___index___">@L["Inventory:ReceivedAt"]</label>
                                <input class="form-control form-control-sm" name="ReceivedAtTexts[@i]" id="ReceivedAtTexts_@i.ToString()_"
                                       value="@Model.ReceivedAtTexts[i]" inputmode="numeric" placeholder="dd/MM/yyyy"
                                       data-default-value="@Model.DefaultDateText"
                                       data-name="ReceivedAtTexts[__index__]" data-id="ReceivedAtTexts___index___" />
                                <span class="text-danger small" data-valmsg-for="ReceivedAtTexts[@i]"
                                      data-valmsg-for-template="ReceivedAtTexts[__index__]" data-valmsg-replace="true"></span>
                            </td>
                            <td class="vpl-line-editor-col-number">
                                <label class="visually-hidden" for="Input_Lines_@i.ToString()__UnitCost"
                                       data-for="Input_Lines___index____UnitCost">@L["Inventory:UnitCost"]</label>
                                <input class="form-control form-control-sm" name="Input.Lines[@i].UnitCost" id="Input_Lines_@i.ToString()__UnitCost"
                                       value="@Model.Input.Lines[i].UnitCost" data-name="Input.Lines[__index__].UnitCost"
                                       data-id="Input_Lines___index____UnitCost" />
                                <span class="text-danger small" data-valmsg-for="Input.Lines[@i].UnitCost"
                                      data-valmsg-for-template="Input.Lines[__index__].UnitCost" data-valmsg-replace="true"></span>
                            </td>
                            <td class="vpl-line-editor-col-action text-end">
                                <button class="btn btn-outline-danger btn-sm vpl-line-editor-icon-button"
                                        type="button"
                                        data-remove-line
                                        title="@L["Inventory:RemoveLine"]"
                                        aria-label="@L["Inventory:RemoveLine"]">
                                    <i class="fa fa-trash"></i>
                                </button>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>

            <button class="btn btn-outline-secondary btn-sm mt-3 vpl-line-editor-action" type="button" id="add-receipt-line"><i class="fa fa-plus"></i> @L["Inventory:AddLine"]</button>
            <button class="btn btn-primary btn-sm mt-3" type="submit">@L["Inventory:Post"]</button>
        </form>
    </abp-card-body>
</abp-card>

<template id="receipt-line-row-template">
    <tr data-inventory-line-row data-line-editor-row>
        <td class="vpl-line-editor-col-main">
            <label class="visually-hidden" data-for="Input_Lines___index____StockItemId">@L["Inventory:StockItem"]</label>
            <select class="form-select form-select-sm"
                    data-dynamic-select2="disabled"
                    data-name="Input.Lines[__index__].StockItemId"
                    data-id="Input_Lines___index____StockItemId">
                <option value="">@L["Select"]</option>
                @foreach (var option in Model.StockItemOptions)
                {
                    <option value="@option.Value">@option.Text</option>
                }
            </select>
            <span class="text-danger small" data-valmsg-for-template="Input.Lines[__index__].StockItemId" data-valmsg-replace="true"></span>
        </td>
        <td class="vpl-line-editor-col-number">
            <label class="visually-hidden" data-for="Input_Lines___index____Quantity">@L["Inventory:Quantity"]</label>
            <input class="form-control form-control-sm" value="" data-name="Input.Lines[__index__].Quantity" data-id="Input_Lines___index____Quantity" />
            <span class="text-danger small" data-valmsg-for-template="Input.Lines[__index__].Quantity" data-valmsg-replace="true"></span>
        </td>
        <td class="vpl-line-editor-col-text">
            <label class="visually-hidden" data-for="Input_Lines___index____LotNo">@L["Inventory:LotNo"]</label>
            <input class="form-control form-control-sm" value="" data-name="Input.Lines[__index__].LotNo" data-id="Input_Lines___index____LotNo" />
            <span class="text-danger small" data-valmsg-for-template="Input.Lines[__index__].LotNo" data-valmsg-replace="true"></span>
        </td>
        <td class="vpl-line-editor-col-date">
            <label class="visually-hidden" data-for="ReceivedAtTexts___index___">@L["Inventory:ReceivedAt"]</label>
            <input class="form-control form-control-sm" inputmode="numeric" placeholder="dd/MM/yyyy"
                   data-default-value="@Model.DefaultDateText"
                   data-name="ReceivedAtTexts[__index__]" data-id="ReceivedAtTexts___index___" />
            <span class="text-danger small" data-valmsg-for-template="ReceivedAtTexts[__index__]" data-valmsg-replace="true"></span>
        </td>
        <td class="vpl-line-editor-col-number">
            <label class="visually-hidden" data-for="Input_Lines___index____UnitCost">@L["Inventory:UnitCost"]</label>
            <input class="form-control form-control-sm" value="" data-name="Input.Lines[__index__].UnitCost" data-id="Input_Lines___index____UnitCost" />
            <span class="text-danger small" data-valmsg-for-template="Input.Lines[__index__].UnitCost" data-valmsg-replace="true"></span>
        </td>
        <td class="vpl-line-editor-col-action text-end">
            <button class="btn btn-outline-danger btn-sm vpl-line-editor-icon-button"
                    type="button"
                    data-remove-line
                    title="@L["Inventory:RemoveLine"]"
                    aria-label="@L["Inventory:RemoveLine"]">
                <i class="fa fa-trash"></i>
            </button>
        </td>
    </tr>
</template>

@section styles {
    <abp-style src="/Pages/Shared/LineEditors.css" />
}

@section scripts {
    <abp-script src="/Pages/Shared/DynamicRowSelects.js" />
    <abp-script src="/Pages/Inventory/Posting.js" />
}
