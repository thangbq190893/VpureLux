@page
@model VPureLux.Web.Pages.Inventory.LedgerModel
@inject Microsoft.Extensions.Localization.IStringLocalizer<VPureLux.Localization.VPureLuxResource> L
<h2>@L["Inventory:Ledger"]</h2>
<form method="get" class="row g-2 mb-3">
    <div class="col-md-4">
        <label asp-for="WarehouseId" class="form-label">@L["Inventory:Warehouse"]</label>
        <select asp-for="WarehouseId" asp-items="Model.WarehouseOptions" class="form-select">
            <option value="">@L["Select"]</option>
        </select>
    </div>
    <div class="col-md-4">
        <label asp-for="StockItemId" class="form-label">@L["Inventory:StockItem"]</label>
        <select asp-for="StockItemId" asp-items="Model.StockItemOptions" class="form-select">
            <option value="">@L["Select"]</option>
        </select>
    </div>
    <div class="col-md-4 d-flex align-items-end gap-2">
        <button type="submit" class="btn btn-primary">@L["Inventory:ApplyFilter"]</button>
        <a class="btn btn-outline-secondary" asp-page="/Inventory/Ledger">@L["Inventory:ClearFilter"]</a>
    </div>
</form>
@if (Model.Items.Count == 0)
{
    <div class="alert alert-light border">@L["Inventory:NoLedgerEntries"]</div>
}
else
{
<abp-table striped-rows="true">
    <thead>
        <tr>
            <th>@L["Inventory:PostedAt"]</th>
            <th>@L["Inventory:Warehouse"]</th>
            <th>@L["Inventory:Type"]</th>
            <th>@L["Inventory:Reason"]</th>
            <th>@L["Inventory:IssueCost"]</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var x in Model.Items)
    {
        <tr>
            <td>@x.PostedAt</td>
            <td>@Model.GetWarehouseLabel(x.WarehouseId)</td>
            <td>@L[$"Inventory:TransactionType:{x.Type}"]</td>
            <td>@x.Reason</td>
            <td>@x.TotalIssueCost</td>
        </tr>
    }
    </tbody>
</abp-table>
}
