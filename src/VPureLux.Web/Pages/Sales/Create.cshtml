@page
@model VPureLux.Web.Pages.Sales.CreateModel
@inject Microsoft.Extensions.Localization.IStringLocalizer<VPureLux.Localization.VPureLuxResource> L
@using System.Globalization
@using VPureLux
@{ ViewData["Title"] = L["Sales:Create"]; }
<div id="SalesCreatePage"
     data-sales-context-endpoint="@Url.Page(null, "ProductContext")"
     data-sales-product-not-eligible="@L["Sales:ProductNotSaleEligible"]"
     data-sales-override-reason-required="@L[VPureLuxDomainErrorCodes.SalesOverrideReasonRequired]">
    <abp-card>
        <abp-card-header>
            <h2>@L["Sales:Create"]</h2>
        </abp-card-header>
        <abp-card-body>
            <form method="post">
                <abp-validation-summary />
                <div class="alert alert-danger d-none" role="alert" data-sales-create-alert></div>

                <label asp-for="Input.CustomerId">@L["Sales:Customer"]</label>
                <select asp-for="Input.CustomerId" asp-items="Model.Customers" class="form-select mb-3"></select>

                <label asp-for="Input.WarehouseId">@L["Sales:Warehouse"]</label>
                <select asp-for="Input.WarehouseId" asp-items="Model.Warehouses" class="form-select mb-3"></select>

                <abp-input asp-for="Input.OrderDate" />

                <div id="sales-create-lines">
                    @for (var i = 0; i < Model.Input.Lines.Count; i++)
                    {
                        <div class="border rounded p-3 mb-3 sales-line-row" data-sales-line-row data-sales-line-index="@i">
                            <label class="form-label" for="Input_Lines_@(i)__ProductId">@L["Sales:ProductSku"]</label>
                            <select asp-for="Input.Lines[i].ProductId"
                                    asp-items="Model.Products"
                                    class="form-select w-100 mb-2 sales-line-product"
                                    data-sales-product-select
                                    data-sales-line-index="@i"></select>
                            <span asp-validation-for="Input.Lines[i].ProductId" class="text-danger d-block mb-2"></span>

                            <div class="alert alert-light border mb-3 py-2" data-sales-product-context>
                                @L["Sales:SelectProductForContext"]
                            </div>
                            <div class="small text-danger d-none mb-2" data-sales-product-eligibility></div>

                            <div class="mb-3">
                                <label class="form-label" for="Input_Lines_@(i)__Quantity">@L["Sales:Quantity"]</label>
                                <input type="number"
                                       step="any"
                                       min="0.0001"
                                       name="Input.Lines[@(i)].Quantity"
                                       id="Input_Lines_@(i)__Quantity"
                                       class="form-control sales-line-quantity"
                                       value="@(Model.Input.Lines[i].Quantity == 0 ? "1" : Model.Input.Lines[i].Quantity.ToString(CultureInfo.InvariantCulture))" />
                                <span asp-validation-for="Input.Lines[i].Quantity" class="text-danger"></span>
                            </div>
                            <div class="mb-3">
                                <label class="form-label" for="Input_Lines_@(i)__ActualSellingPrice">@L["Sales:ActualPrice"]</label>
                                <input type="number"
                                       step="any"
                                       min="0"
                                       name="Input.Lines[@(i)].ActualSellingPrice"
                                       id="Input_Lines_@(i)__ActualSellingPrice"
                                       class="form-control sales-line-actual-price"
                                       data-sales-actual-price
                                       value="@(Model.Input.Lines[i].ActualSellingPrice?.ToString(CultureInfo.InvariantCulture) ?? string.Empty)" />
                                <span asp-validation-for="Input.Lines[i].ActualSellingPrice" class="text-danger"></span>
                            </div>
                            <div class="mb-3">
                                <label asp-for="Input.Lines[i].OverrideReason" class="form-label">@L["Sales:OverrideReason"]</label>
                                <input asp-for="Input.Lines[i].OverrideReason" class="form-control sales-line-override" />
                                <span asp-validation-for="Input.Lines[i].OverrideReason" class="text-danger"></span>
                                <span class="text-danger d-block small d-none" data-sales-override-validation></span>
                            </div>
                            <div class="text-end">
                                <button type="button" class="btn btn-outline-danger btn-sm remove-sales-line" title="@L["Delete"]">
                                    <i class="fa fa-trash"></i> @L["Delete"]
                                </button>
                            </div>
                        </div>
                    }
                </div>
                <button type="button" id="add-sales-line" class="btn btn-outline-secondary mb-3">
                    <i class="fa fa-plus"></i> @L["Sales:AddLine"]
                </button>

                <button class="btn btn-primary" type="submit">@L["Save"]</button>
                <a class="btn btn-secondary" asp-page="/Sales/Index">@L["Cancel"]</a>
            </form>
        </abp-card-body>
    </abp-card>
</div>

<div id="sales-product-context-data" class="d-none" hidden aria-hidden="true">@Model.GetProductContextsJson()</div>

<template id="sales-line-row-template">
    <div class="border rounded p-3 mb-3 sales-line-row" data-sales-line-row>
        <label class="form-label" data-for="Input_Lines___index____ProductId">@L["Sales:ProductSku"]</label>
        <select class="form-select w-100 mb-2 sales-line-product"
                data-sales-product-select
                data-name="Input.Lines[__index__].ProductId"
                data-id="Input_Lines___index____ProductId">
            @foreach (var option in Model.Products)
            {
                <option value="@option.Value">@option.Text</option>
            }
        </select>

        <div class="alert alert-light border mb-3 py-2" data-sales-product-context>
            @L["Sales:SelectProductForContext"]
        </div>
        <div class="small text-danger d-none mb-2" data-sales-product-eligibility></div>

        <div class="mb-3">
            <label class="form-label" data-for="Input_Lines___index____Quantity">@L["Sales:Quantity"]</label>
            <input type="number" step="any" min="0.0001" class="form-control sales-line-quantity"
                   value="1"
                   data-name="Input.Lines[__index__].Quantity"
                   data-id="Input_Lines___index____Quantity" />
        </div>
        <div class="mb-3">
            <label class="form-label" data-for="Input_Lines___index____ActualSellingPrice">@L["Sales:ActualPrice"]</label>
            <input type="number" step="any" min="0" class="form-control sales-line-actual-price"
                   data-sales-actual-price
                   data-name="Input.Lines[__index__].ActualSellingPrice"
                   data-id="Input_Lines___index____ActualSellingPrice" />
        </div>
        <div class="mb-3">
            <label class="form-label" data-for="Input_Lines___index____OverrideReason">@L["Sales:OverrideReason"]</label>
            <input type="text" class="form-control sales-line-override"
                   data-name="Input.Lines[__index__].OverrideReason"
                   data-id="Input_Lines___index____OverrideReason" />
            <span class="text-danger d-block small d-none" data-sales-override-validation></span>
        </div>
        <div class="text-end">
            <button type="button" class="btn btn-outline-danger btn-sm remove-sales-line" title="@L["Delete"]">
                <i class="fa fa-trash"></i> @L["Delete"]
            </button>
        </div>
    </div>
</template>

@section scripts {
    <abp-script src="/Pages/Shared/DynamicRowSelects.js" />
    <abp-script src="/Pages/Sales/SalesProductContext.js" />
    <abp-script src="/Pages/Sales/SalesCreateLines.js" />
}
