@page
@model VPureLux.Web.Pages.Sales.CreateModel
@inject Microsoft.Extensions.Localization.IStringLocalizer<VPureLux.Localization.VPureLuxResource> L
@{ ViewData["Title"] = L["Sales:Create"]; }
<div id="SalesCreatePage" data-sales-context-endpoint="@Url.Page(null, "ProductContext")">
    <abp-card>
        <abp-card-header>
            <h2>@L["Sales:Create"]</h2>
        </abp-card-header>
        <abp-card-body>
            <form method="post">
                <abp-validation-summary />

                <label asp-for="Input.CustomerId">@L["Sales:Customer"]</label>
                <select asp-for="Input.CustomerId" asp-items="Model.Customers" class="form-select mb-3"></select>

                <label asp-for="Input.WarehouseId">@L["Sales:Warehouse"]</label>
                <select asp-for="Input.WarehouseId" asp-items="Model.Warehouses" class="form-select mb-3"></select>

                <abp-input asp-for="Input.OrderDate" />

                <label asp-for="Input.Lines[0].ProductId">@L["Sales:ProductSku"]</label>
                <select asp-for="Input.Lines[0].ProductId" asp-items="Model.Products" class="form-select mb-2" data-sales-product-selector></select>

                <div class="alert alert-light border mb-3" data-sales-product-context>
                    @L["Sales:SelectProductForContext"]
                </div>

                <abp-input asp-for="Input.Lines[0].Quantity" />
                <div class="mb-3">
                    <label asp-for="Input.Lines[0].ActualSellingPrice" class="form-label">@L["Sales:ActualPrice"]</label>
                    <input asp-for="Input.Lines[0].ActualSellingPrice" class="form-control" data-sales-actual-price />
                    <span asp-validation-for="Input.Lines[0].ActualSellingPrice" class="text-danger"></span>
                </div>
                <abp-input asp-for="Input.Lines[0].OverrideReason" />

                <button class="btn btn-primary" type="submit">@L["Save"]</button>
                <a class="btn btn-secondary" asp-page="/Sales/Index">@L["Cancel"]</a>
            </form>
        </abp-card-body>
    </abp-card>
</div>

@section scripts {
    <abp-script src="/Pages/Sales/Create.js" />
}
