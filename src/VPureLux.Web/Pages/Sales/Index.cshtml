@page
@model VPureLux.Web.Pages.Sales.IndexModel
@inject Microsoft.Extensions.Localization.IStringLocalizer<VPureLux.Localization.VPureLuxResource> L
@inject Microsoft.AspNetCore.Authorization.IAuthorizationService AuthorizationService
@using VPureLux.Permissions
@{ ViewData["Title"] = L["Sales:Title"]; }
@{ var canViewCustomerHistory = Model.CanViewHistory && (await AuthorizationService.AuthorizeAsync(User, null, VPureLuxPermissions.Sales.ViewProfit)).Succeeded; }
<div class="d-flex justify-content-between align-items-center mb-4"><h2>@L["Sales:Title"]</h2><div>
@if(canViewCustomerHistory){<a class="btn btn-outline-secondary" asp-page="/Sales/CustomerHistory">@L["Sales:CustomerHistory"]</a>}
<a class="btn btn-outline-secondary" asp-page="/Sales/History">@L["Sales:History"]</a>
@if(Model.CanCreate){<a class="btn btn-primary" asp-page="/Sales/Create">@L["Sales:Create"]</a>}
</div></div>
<abp-table striped-rows="true"><thead><tr><th>@L["Sales:OrderNo"]</th><th>@L["Sales:OrderDate"]</th><th>@L["Sales:Customer"]</th><th>@L["Sales:Status"]</th><th>@L["Sales:Revenue"]</th><th></th></tr></thead><tbody>
@foreach(var order in Model.Orders.Items){<tr><td>@order.OrderNo</td><td>@order.OrderDate</td><td>@(string.IsNullOrEmpty(order.CustomerNameSnapshot) ? L["Sales:CustomerContextUnavailable"] : order.CustomerNameSnapshot)</td><td>@L[$"Sales:Status:{order.Status}"]</td><td>@order.TotalRevenueAmount</td><td><a class="btn btn-sm btn-outline-primary" asp-page="/Sales/Details" asp-route-id="@order.Id">@L["Details"]</a></td></tr>}
</tbody></abp-table>
