@page
@model VPureLux.Web.Pages.Sales.IndexModel
@inject Microsoft.Extensions.Localization.IStringLocalizer<VPureLux.Localization.VPureLuxResource> L
@inject Microsoft.AspNetCore.Authorization.IAuthorizationService AuthorizationService
@using VPureLux.Permissions
@using System.Globalization
@{
    ViewData["Title"] = L["Sales:Title"];
    var canViewCustomerHistory = Model.CanViewHistory && (await AuthorizationService.AuthorizeAsync(User, null, VPureLuxPermissions.Sales.ViewProfit)).Succeeded;
}

@functions {
    private static readonly CultureInfo Vi = CultureInfo.GetCultureInfo("vi-VN");

    private static string FormatMoney(decimal value)
    {
        var amount = decimal.Round(value, 0, MidpointRounding.AwayFromZero);
        return amount.ToString("#,0", Vi) + " ₫";
    }

    private static string FormatDate(DateTime value)
    {
        return value.ToString("dd/MM/yyyy", Vi);
    }
}

<div class="vpl-page vpl-inquiry-page">
    <div class="vpl-page-header">
        <h2 class="vpl-page-title mb-0">@L["Sales:Title"]</h2>
        <div class="vpl-btn-toolbar">
            @if (canViewCustomerHistory)
            {
                <a class="btn btn-outline-secondary" asp-page="/Sales/CustomerHistory">@L["Sales:CustomerHistory"]</a>
            }
            <a class="btn btn-outline-secondary" asp-page="/Sales/History">@L["Sales:History"]</a>
            @if (Model.CanCreate)
            {
                <a class="btn btn-primary" asp-page="/Sales/Create">@L["Sales:Create"]</a>
            }
        </div>
    </div>

    <abp-card class="vpl-inquiry-results-card vpl-card-dense">
        <abp-card-body>
            <abp-table striped-rows="true" class="vpl-table-dense">
                <thead>
                    <tr>
                        <th>@L["Sales:OrderNo"]</th>
                        <th>@L["Sales:OrderDate"]</th>
                        <th>@L["Sales:Customer"]</th>
                        <th>@L["Sales:Status"]</th>
                        <th>@L["Sales:Revenue"]</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var order in Model.Orders.Items)
                {
                    <tr>
                        <td>@order.OrderNo</td>
                        <td>@FormatDate(order.OrderDate)</td>
                        <td>@(string.IsNullOrEmpty(order.CustomerNameSnapshot) ? L["Sales:CustomerContextUnavailable"] : order.CustomerNameSnapshot)</td>
                        <td>@L[$"Sales:Status:{order.Status}"]</td>
                        <td>@FormatMoney(order.TotalRevenueAmount)</td>
                        <td>
                            <a class="btn btn-sm btn-outline-secondary" asp-page="/Sales/Details" asp-route-id="@order.Id">@L["Details"]</a>
                        </td>
                    </tr>
                }
                </tbody>
            </abp-table>
        </abp-card-body>
    </abp-card>
</div>
