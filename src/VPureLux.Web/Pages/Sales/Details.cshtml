@page "{id:guid}"
@model VPureLux.Web.Pages.Sales.DetailsModel
@inject Microsoft.Extensions.Localization.IStringLocalizer<VPureLux.Localization.VPureLuxResource> L
@inject Microsoft.AspNetCore.Authorization.IAuthorizationService AuthorizationService
@using VPureLux.Permissions
@using System.Globalization
@{ ViewData["Title"] = Model.Order.OrderNo; }
@{ var canViewCost = (await AuthorizationService.AuthorizeAsync(User, null, VPureLuxPermissions.Sales.ViewCost)).Succeeded; }
@{ var canViewProfit = (await AuthorizationService.AuthorizeAsync(User, null, VPureLuxPermissions.Sales.ViewProfit)).Succeeded; }

@functions {
    private static readonly CultureInfo Vi = CultureInfo.GetCultureInfo("vi-VN");

    private static string FormatMoney(decimal value)
    {
        var amount = decimal.Round(value, 0, MidpointRounding.AwayFromZero);
        return amount.ToString("#,0", Vi) + " ₫";
    }

    private static string FormatMoney(decimal? value)
    {
        return value.HasValue ? FormatMoney(value.Value) : string.Empty;
    }

    private static string FormatQuantity(decimal value)
    {
        if (value == decimal.Truncate(value))
        {
            return decimal.Truncate(value).ToString("0", Vi);
        }

        return value.ToString("0.####", Vi);
    }
}

<div id="SalesDetailsPage" class="vpl-page" data-sales-success-message="@Model.SuccessMessage">
    <div class="vpl-page-header">
        <h2 class="vpl-page-title mb-0">@Model.Order.OrderNo</h2>
        <div class="vpl-btn-toolbar">
            @if (Model.CanEdit)
            {
                <a class="btn btn-sm btn-primary" asp-page="/Sales/Edit" asp-route-id="@Model.Order.Id">@L["Edit"]</a>
            }
            @if (Model.CanConfirm)
            {
                <form method="post"
                      asp-page-handler="Confirm"
                      class="d-inline"
                      data-sales-action-form
                      data-confirm-message="@L["Sales:ConfirmOrderMessage"]">
                    <input type="hidden" asp-for="Confirmation.IdempotencyKey" />
                    <button class="btn btn-sm btn-success">@L["Sales:Confirm"]</button>
                </form>
            }
            @if (Model.CanCancel)
            {
                <form method="post"
                      asp-page-handler="Cancel"
                      class="d-inline"
                      data-sales-action-form
                      data-confirm-message="@L["Sales:CancelOrderMessage"]">
                    <button class="btn btn-sm btn-danger">@L["Sales:Cancel"]</button>
                </form>
            }
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
    {
        <div class="alert alert-success" role="alert">@Model.SuccessMessage</div>
    }
    @if (!string.IsNullOrWhiteSpace(Model.ConfirmErrorMessage))
    {
        <div class="alert alert-danger" role="alert">@Model.ConfirmErrorMessage</div>
    }

    <abp-validation-summary />

    <abp-card class="vpl-card-dense mb-3">
        <abp-card-body>
            <dl class="row mb-0">
                <dt class="col-sm-3">@L["Sales:Status"]</dt>
                <dd class="col-sm-9">@L[$"Sales:Status:{Model.Order.Status}"]</dd>
                <dt class="col-sm-3">@L["Sales:Customer"]</dt>
                <dd class="col-sm-9">@Model.CustomerDisplay</dd>
                @if (Model.IsDraft)
                {
                    <dt class="col-sm-3">@L["Sales:DraftEstimatedRevenue"]</dt>
                    <dd class="col-sm-9">@FormatMoney(Model.DraftEstimatedRevenueAmount)</dd>
                }
                <dt class="col-sm-3">@L["Sales:ConfirmedRevenue"]</dt>
                <dd class="col-sm-9">@FormatMoney(Model.Order.TotalRevenueAmount)</dd>
                @if (canViewCost)
                {
                    <dt class="col-sm-3">@L["Sales:ConfirmedCost"]</dt>
                    <dd class="col-sm-9">@FormatMoney(Model.Order.TotalCostAmount)</dd>
                }
                @if (canViewProfit)
                {
                    <dt class="col-sm-3">@L["Sales:ConfirmedProfit"]</dt>
                    <dd class="col-sm-9">@FormatMoney(Model.Order.TotalProfitAmount)</dd>
                }
                @if (Model.IsDraft)
                {
                    <dt class="col-sm-3">@L["Sales:FinancialTotals"]</dt>
                    <dd class="col-sm-9 text-muted">@L["Sales:DraftFinancialTotalsNote"]</dd>
                }
            </dl>
        </abp-card-body>
    </abp-card>

    <abp-card class="vpl-card-dense mb-3">
        <abp-card-body>
            <abp-table striped-rows="true" class="vpl-table-dense">
                <thead>
                <tr>
                    <th>#</th>
                    <th>@L["Sales:ProductSku"]</th>
                    <th>@L["Sales:Quantity"]</th>
                    <th>@L["Sales:SuggestedPrice"]</th>
                    <th>@L["Sales:ActualPrice"]</th>
                    <th>@L["Sales:OverrideReason"]</th>
                    @if (canViewCost)
                    {
                        <th>@L["Sales:CostPrice"]</th>
                        <th>@L["Sales:Cost"]</th>
                    }
                    @if (canViewProfit)
                    {
                        <th>@L["Sales:Profit"]</th>
                    }
                </tr>
                </thead>
                <tbody>
                @foreach (var line in Model.Order.Lines)
                {
                    <tr>
                        <td>@line.LineNo</td>
                        <td>
                            <div>@Model.GetProductLabel(line)</div>
                            <span class="@Model.GetBomBadgeClass(line)">@Model.GetBomStatusText(line)</span>
                            @if (line.BomSnapshotItems.Count > 0)
                            {
                                <ul class="mb-0 mt-1 small text-muted">
                                @foreach (var item in line.BomSnapshotItems)
                                {
                                    <li>@item.ComponentCode - @item.ComponentName: @FormatQuantity(item.TotalRequiredQuantity) @item.Unit</li>
                                }
                                </ul>
                            }
                        </td>
                        <td>@FormatQuantity(line.Quantity)</td>
                        <td>@FormatMoney(line.SuggestedPriceSnapshot)</td>
                        <td>@FormatMoney(line.ActualSellingPrice)</td>
                        <td>@line.OverrideReason</td>
                        @if (canViewCost)
                        {
                            if (Model.IsDraft)
                            {
                                <td class="text-muted">@L["Sales:CalculatedAfterConfirmation"]</td>
                                <td class="text-muted">@L["Sales:CalculatedAfterConfirmation"]</td>
                            }
                            else
                            {
                                <td>@FormatMoney(line.CostPriceSnapshot)</td>
                                <td>@FormatMoney(line.CostAmountSnapshot)</td>
                            }
                        }
                        @if (canViewProfit)
                        {
                            if (Model.IsDraft)
                            {
                                <td class="text-muted">@L["Sales:CalculatedAfterConfirmation"]</td>
                            }
                            else
                            {
                                <td>@FormatMoney(line.ProfitAmount)</td>
                            }
                        }
                    </tr>
                }
                </tbody>
            </abp-table>
        </abp-card-body>
    </abp-card>

    <a class="btn btn-sm btn-secondary" asp-page="/Sales/Index">@L["Back"]</a>
</div>

@section scripts {
    <abp-script src="/Pages/Sales/Details.js" />
}
