@page
@model VPureLux.Web.Pages.Sales.HistoryModel
@inject Microsoft.Extensions.Localization.IStringLocalizer<VPureLux.Localization.VPureLuxResource> L
@inject Microsoft.AspNetCore.Authorization.IAuthorizationService AuthorizationService
@using VPureLux.Permissions
@{ var canViewProfit = (await AuthorizationService.AuthorizeAsync(User, null, VPureLuxPermissions.Sales.ViewProfit)).Succeeded; }
<h2>@L["Sales:History"]</h2><abp-table striped-rows="true"><thead><tr><th>@L["Sales:OrderNo"]</th><th>@L["Sales:OrderDate"]</th><th>@L["Sales:Customer"]</th><th>@L["Sales:Revenue"]</th>@if(canViewProfit){<th>@L["Sales:Profit"]</th>}<th></th></tr></thead><tbody>
@foreach(var order in Model.Orders.Items){<tr><td>@order.OrderNo</td><td>@order.OrderDate</td><td>@order.CustomerCodeSnapshot - @order.CustomerNameSnapshot</td><td>@order.TotalRevenueAmount</td>@if(canViewProfit){<td>@order.TotalProfitAmount</td>}<td><a class="btn btn-sm btn-outline-primary" asp-page="/Sales/Details" asp-route-id="@order.Id">@L["Details"]</a></td></tr>}
</tbody></abp-table>
