@page
@model VPureLux.Web.Pages.Catalog.Components.IndexModel
@inject Microsoft.Extensions.Localization.IStringLocalizer<VPureLux.Localization.VPureLuxResource> L
@{
    ViewData["Title"] = L["Catalog:Components"];
}

@section scripts {
    <abp-script src="/Pages/Catalog/CatalogIndex.js" />
}

<div data-catalog-index
     data-create-view-url="Catalog/Components/CreateModal"
     data-edit-view-url="Catalog/Components/EditModal"
     data-details-view-url="Catalog/Components/DetailsModal"
     data-saved-message="@L["Catalog:ComponentSavedSuccessfully"]"
     data-status-success="@(string.IsNullOrWhiteSpace(Model.StatusMessageKey) ? string.Empty : L[Model.StatusMessageKey].Value)"></div>

<abp-card>
    <abp-card-header>
        <abp-row>
            <abp-column size-md="_6">
                <h2>@L["Catalog:Components"]</h2>
            </abp-column>
            <abp-column size-md="_6" class="text-end">
                @if (Model.CanCreate)
                {
                    <a asp-page="/Catalog/Components/Create" class="btn btn-primary" data-catalog-create><i class="fa fa-plus"></i> @L["Catalog:NewComponent"]</a>
                }
            </abp-column>
        </abp-row>
    </abp-card-header>
    <abp-card-body>
        <form method="get" class="mb-3">
            <abp-row>
                <abp-column size-md="_4">
                    <input asp-for="Keyword" class="form-control" placeholder="@L["Search"]" />
                </abp-column>
                <abp-column size-md="_2">
                    <abp-button button-type="Secondary" type="submit">@L["Search"]</abp-button>
                </abp-column>
            </abp-row>
        </form>
        <abp-table striped-rows="true">
            <thead>
            <tr>
                <th>@L["Catalog:Image"]</th>
                <th>@L["Catalog:Code"]</th>
                <th>@L["Catalog:Name"]</th>
                <th>@L["Catalog:Unit"]</th>
                <th>@L["Catalog:Status"]</th>
                @if (Model.CanViewPricingContext)
                {
                    <th class="text-end">@L["Catalog:CurrentComponentSuggestedPrice"]</th>
                }
                <th class="text-end">@L["Actions"]</th>
            </tr>
            </thead>
            <tbody>
            @foreach (var row in Model.Components)
            {
                <tr>
                    <td style="width:72px">
                        @if (row.Component.HasImage)
                        {
                            <img src="/api/catalog/components/@row.Component.Id/thumbnail?v=@row.Component.ImageHash"
                                 loading="lazy" width="56" height="56" style="object-fit:contain"
                                 class="border rounded" alt="@row.Component.Name" />
                        }
                        else
                        {
                            <div class="border rounded d-flex align-items-center justify-content-center text-muted"
                                 style="width:56px;height:56px" title="@L["Catalog:NoImage"]">-</div>
                        }
                    </td>
                    <td>@row.Component.Code</td>
                    <td>@row.Component.Name</td>
                    <td>@row.Component.Unit</td>
                    <td>@L[$"Status:{row.Component.Status}"]</td>
                    @if (Model.CanViewPricingContext)
                    {
                        <td class="text-end">
                            @(row.CurrentSuggestedSellingPrice == null
                                ? L["Catalog:NoComponentSuggestedPrice"].Value
                                : $"{row.CurrentSuggestedSellingPrice.Price:N0} {row.CurrentSuggestedSellingPrice.Currency}")
                        </td>
                    }
                    <td class="text-end">
                        <div class="dropdown">
                            <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown">@L["Actions"]</button>
                            <div class="dropdown-menu dropdown-menu-end">
                                <a class="dropdown-item" asp-page="/Catalog/Components/Details" asp-route-id="@row.Component.Id" data-catalog-details data-id="@row.Component.Id">@L["Details"]</a>
                                @if (Model.CanEdit)
                                {
                                    <a class="dropdown-item" asp-page="/Catalog/Components/Edit" asp-route-id="@row.Component.Id" data-catalog-edit data-id="@row.Component.Id">@L["Edit"]</a>
                                    <a class="dropdown-item" asp-page="/Catalog/Components/Edit" asp-route-id="@row.Component.Id">@L["Catalog:ManageImage"]</a>
                                    @if (row.Component.Status == VPureLux.Catalog.CatalogItemStatus.Active)
                                    {
                                        <form method="post"
                                              asp-page-handler="Deactivate"
                                              asp-route-id="@row.Component.Id"
                                              data-catalog-status-form
                                              data-confirm-message="@L["Catalog:ConfirmDeactivateComponent"]">
                                            <button class="dropdown-item" type="submit">@L["Deactivate"]</button>
                                        </form>
                                    }
                                    else
                                    {
                                        <form method="post"
                                              asp-page-handler="Activate"
                                              asp-route-id="@row.Component.Id"
                                              data-catalog-status-form
                                              data-confirm-message="@L["Catalog:ConfirmActivateComponent"]">
                                            <button class="dropdown-item" type="submit">@L["Activate"]</button>
                                        </form>
                                    }
                                }
                            </div>
                        </div>
                    </td>
                </tr>
            }
            </tbody>
        </abp-table>
    </abp-card-body>
</abp-card>
