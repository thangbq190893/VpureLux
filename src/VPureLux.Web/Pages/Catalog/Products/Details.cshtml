@page "{id:guid}"
@model VPureLux.Web.Pages.Catalog.Products.DetailsModel
@inject Microsoft.Extensions.Localization.IStringLocalizer<VPureLux.Localization.VPureLuxResource> L
@{
    ViewData["Title"] = L["Details"];
}

<abp-card>
    <abp-card-header><h2>@L["Details"]</h2></abp-card-header>
    <abp-card-body>
        <dl class="row">
            <dt class="col-sm-3">@L["Catalog:Code"]</dt><dd class="col-sm-9">@Model.Product.Code</dd>
            <dt class="col-sm-3">@L["Catalog:Name"]</dt><dd class="col-sm-9">@Model.Product.Name</dd>
            <dt class="col-sm-3">@L["Catalog:Status"]</dt><dd class="col-sm-9">@L[$"Status:{Model.Product.Status}"]</dd>
            <dt class="col-sm-3">@L["Catalog:Image"]</dt><dd class="col-sm-9">@(Model.Product.HasImage ? L["Catalog:HasImage"] : L["Catalog:NoImage"])</dd>
            @if (!string.IsNullOrWhiteSpace(Model.Product.Description))
            {
                <dt class="col-sm-3">@L["Catalog:Description"]</dt><dd class="col-sm-9">@Model.Product.Description</dd>
            }
        </dl>
        <a class="btn btn-secondary" asp-page="/Catalog/Products/Index">@L["Back"]</a>
    </abp-card-body>
</abp-card>
