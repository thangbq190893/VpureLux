@page
@model VPureLux.Web.Pages.Catalog.Products.CreateModel
@inject Microsoft.Extensions.Localization.IStringLocalizer<VPureLux.Localization.VPureLuxResource> L
@{
    ViewData["Title"] = L["Catalog:NewProduct"];
}

<abp-card>
    <abp-card-header>
        <h2>@L["Catalog:NewProduct"]</h2>
    </abp-card-header>
    <abp-card-body>
        <form method="post" enctype="multipart/form-data">
            <abp-input asp-for="Input.Code" />
            <abp-input asp-for="Input.Name" />
            <abp-input asp-for="Input.Description" />
            <label class="form-label" for="Image">@L["Catalog:UploadImage"]</label>
            <input asp-for="Image" type="file" accept=".jpg,.jpeg,.png,.webp" class="form-control"
                   data-catalog-image-input data-preview-target="#image-preview" />
            <div class="form-text">@L["Catalog:SupportedImageFormats"]</div>
            <img id="image-preview" class="d-none mt-3 border rounded" width="96" height="96"
                 style="object-fit:contain" alt="@L["Catalog:ImagePreview"]" />
            <div class="mt-3">
                <abp-button button-type="Primary" type="submit">@L["Save"]</abp-button>
                <a class="btn btn-secondary" asp-page="/Catalog/Products/Index">@L["Cancel"]</a>
            </div>
        </form>
    </abp-card-body>
</abp-card>

@section scripts {
    <abp-script src="/Pages/Catalog/catalog-image-preview.js" />
}
