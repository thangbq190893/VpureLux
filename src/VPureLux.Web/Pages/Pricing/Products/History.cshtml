@page "/Pricing/Products/{productId:guid}"
@model VPureLux.Web.Pages.Pricing.Products.HistoryModel
@using VPureLux.Web.Pages.Pricing
@inject Microsoft.Extensions.Localization.IStringLocalizer<VPureLux.Localization.VPureLuxResource> L
@{ ViewData["Title"] = L["Pricing:ProductSuggestedPriceHistory"]; }

<abp-row>
    <abp-column size-md="_8"><h2>@L["Pricing:ProductSuggestedPriceHistory"]</h2></abp-column>
    <abp-column size-md="_4" class="text-end">
        @if (Model.CanCreate)
        {
            <a class="btn btn-primary" asp-page="/Pricing/Products/Create" asp-route-productId="@Model.ProductId">@L["Pricing:CreateNewVersion"]</a>
        }
    </abp-column>
</abp-row>

<abp-row class="mt-3">
    <abp-column size-md="_6">
        <h5>@L["Pricing:CurrentVersion"]</h5>
        @if (Model.CurrentVersion == null)
        {
            <p class="text-muted">@L["Pricing:NoVersion"]</p>
        }
        else
        {
            <dl class="row"><dt class="col-5">@L["Pricing:Price"]</dt><dd class="col-7">@Model.CurrentVersion.Price.ToString("N2") @Model.CurrentVersion.Currency</dd><dt class="col-5">@L["Pricing:Reason"]</dt><dd class="col-7">@Model.CurrentVersion.Reason</dd></dl>
        }
    </abp-column>
    <abp-column size-md="_6">
        <h5>@L["Pricing:HistoricalLookup"]</h5>
        <form method="get">
            <div class="input-group">
                <input asp-for="LookupDateText" class="form-control" inputmode="numeric" placeholder="dd/MM/yyyy" aria-label="@L["Pricing:HistoricalLookup"]" />
                <button class="btn btn-outline-primary" type="submit">@L["Search"]</button>
            </div>
            <span asp-validation-for="LookupDateText" class="text-danger"></span>
        </form>
        @if (Model.LookupDate.HasValue)
        {
            <p class="mt-2">@(Model.HistoricalVersion == null ? L["Pricing:NoVersion"] : $"{Model.HistoricalVersion.Price:N2} {Model.HistoricalVersion.Currency} - {Model.HistoricalVersion.Reason}")</p>
        }
    </abp-column>
</abp-row>

<h5 class="mt-4">@L["Pricing:VersionTimeline"]</h5>
<div class="border-start border-2 ps-4">
@foreach (var version in Model.Versions)
{
    <div class="mb-4 position-relative">
        <strong>@L["Pricing:Version"] @version.VersionNo</strong>
        <span class="badge bg-secondary ms-2">@L[$"Pricing:Status:{version.Status}"]</span>
        <div>@version.Price.ToString("N2") @version.Currency</div>
        <div class="text-muted">@PricingDateUi.Format(version.EffectiveFrom) - @(version.EffectiveTo.HasValue ? PricingDateUi.Format(version.EffectiveTo.Value) : L["Pricing:OpenEnded"])</div>
        <div>@version.Reason</div>
    </div>
}
</div>
<a class="btn btn-secondary" asp-page="/Pricing/Index">@L["Back"]</a>
