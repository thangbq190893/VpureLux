@page
@model VPureLux.Web.Pages.IndexModel
@using VPureLux.Web.Menus
@using Volo.Abp.AspNetCore.Mvc.UI.Layout
@using Microsoft.AspNetCore.Mvc.Localization
@using VPureLux.Localization
@using Volo.Abp.Users
@inject IPageLayout PageLayout
@inject IHtmlLocalizer<VPureLuxResource> L
@inject ICurrentUser CurrentUser
@{
    PageLayout.Content.Title = L["Menu:Home"].Value;
    PageLayout.Content.BreadCrumb.ShowCurrent = false;
    PageLayout.Content.ShowToolbar = false;
    PageLayout.Content.MenuItemName = VPureLuxMenus.Home;
}

@section styles {
    <abp-style src="/Pages/Index.css" />
}

<div class="vpl-home-welcome">
    <div class="card vpl-home-hero mb-4">
        <div class="card-body">
            @if (!CurrentUser.IsAuthenticated)
            {
                <p class="text-muted mb-2">@L["Welcome"]</p>
            }
            <h1 class="vpl-home-title mb-2">VPURELUX ERP</h1>
            <p class="vpl-home-subtitle text-muted mb-0">
                Hệ thống quản lý nội bộ — tra cứu, nhập liệu và điều phối nghiệp vụ vận hành hàng ngày.
            </p>
            @if (!CurrentUser.IsAuthenticated)
            {
                <a href="/Account/Login" class="btn btn-primary mt-3">
                    <i class="fa-solid fa-right-to-bracket me-1"></i><span>@L["Login"]</span>
                </a>
            }
        </div>
    </div>

    @if (CurrentUser.IsAuthenticated)
    {
        <div class="row g-3">
            <div class="col-md-6 col-lg-4">
                <div class="card h-100 vpl-module-card">
                    <div class="card-body d-flex flex-column">
                        <div class="vpl-module-icon mb-3"><i class="fa fa-cubes"></i></div>
                        <h5 class="card-title">Danh mục</h5>
                        <p class="card-text text-muted flex-grow-1">Quản lý sản phẩm và linh kiện trong hệ thống.</p>
                        <a asp-page="/Catalog/Products/Index" class="stretched-link text-decoration-none fw-semibold">Mở danh mục sản phẩm</a>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-lg-4">
                <div class="card h-100 vpl-module-card">
                    <div class="card-body d-flex flex-column">
                        <div class="vpl-module-icon mb-3"><i class="fa fa-money"></i></div>
                        <h5 class="card-title">Giá</h5>
                        <p class="card-text text-muted flex-grow-1">Tra cứu và cập nhật giá gợi ý cho sản phẩm, linh kiện.</p>
                        <a asp-page="/Pricing/Index" class="stretched-link text-decoration-none fw-semibold">Mở quản lý giá</a>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-lg-4">
                <div class="card h-100 vpl-module-card">
                    <div class="card-body d-flex flex-column">
                        <div class="vpl-module-icon mb-3"><i class="fa fa-sitemap"></i></div>
                        <h5 class="card-title">BOM</h5>
                        <p class="card-text text-muted flex-grow-1">Quản lý định mức nguyên vật liệu theo sản phẩm.</p>
                        <a asp-page="/Bom/Index" class="stretched-link text-decoration-none fw-semibold">Mở BOM</a>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-lg-4">
                <div class="card h-100 vpl-module-card">
                    <div class="card-body d-flex flex-column">
                        <div class="vpl-module-icon mb-3"><i class="fa fa-warehouse"></i></div>
                        <h5 class="card-title">Kho hàng</h5>
                        <p class="card-text text-muted flex-grow-1">Nhập xuất, tồn kho, lô hàng và nhật ký kho.</p>
                        <a asp-page="/Inventory/Index" class="stretched-link text-decoration-none fw-semibold">Mở kho hàng</a>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-lg-4">
                <div class="card h-100 vpl-module-card">
                    <div class="card-body d-flex flex-column">
                        <div class="vpl-module-icon mb-3"><i class="fa fa-shopping-cart"></i></div>
                        <h5 class="card-title">Bán hàng</h5>
                        <p class="card-text text-muted flex-grow-1">Tạo đơn, theo dõi giao dịch và lịch sử bán hàng.</p>
                        <a asp-page="/Sales/Index" class="stretched-link text-decoration-none fw-semibold">Mở bán hàng</a>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-lg-4">
                <div class="card h-100 vpl-module-card">
                    <div class="card-body d-flex flex-column">
                        <div class="vpl-module-icon mb-3"><i class="fa fa-history"></i></div>
                        <h5 class="card-title">Nhật ký nghiệp vụ</h5>
                        <p class="card-text text-muted flex-grow-1">Tra cứu lịch sử thay đổi và hoạt động hệ thống.</p>
                        <a asp-page="/Audit/Index" class="stretched-link text-decoration-none fw-semibold">Mở nhật ký</a>
                    </div>
                </div>
            </div>
        </div>
    }
</div>
